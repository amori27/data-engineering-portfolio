# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=pageviews

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=analytics
POSTGRES_USER=user
POSTGRES_PASSWORD=pass

# Spark
SPARK_MASTER=local[*]
SPARK_APP_NAME=clickstream-pipeline

# API
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info

# Producer
PRODUCER_EVENTS_PER_SECOND=10
PRODUCER_MAX_EVENTS=0
